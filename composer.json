{
    "name": "lombokclarion/app",
    "description": "LombokClarion application skeleton (framework monorepo + example app).",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-openssl": "*",
        "lombokclarion/container": "*",
        "lombokclarion/http": "*",
        "lombokclarion/routing": "*",
        "lombokclarion/bus": "*",
        "lombokclarion/config": "*",
        "lombokclarion/persistence": "*",
        "lombokclarion/view": "*",
        "lombokclarion/console": "*",
        "lombokclarion/security": "*"
    },
    "require-dev": {
        "lombokclarion/testing": "*"
    },
    "repositories": [
        { "type": "path", "url": "packages/container" },
        { "type": "path", "url": "packages/http" },
        { "type": "path", "url": "packages/routing" },
        { "type": "path", "url": "packages/bus" },
        { "type": "path", "url": "packages/config" },
        { "type": "path", "url": "packages/persistence" },
        { "type": "path", "url": "packages/view" },
        { "type": "path", "url": "packages/console" },
        { "type": "path", "url": "packages/security" },
        { "type": "path", "url": "packages/testing" }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
